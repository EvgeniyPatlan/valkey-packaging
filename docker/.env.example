# Valkey Environment Configuration
# Copy this file to .env and set your values
# Usage: docker-compose -f docker-compose.prod.yml up -d

# Password for Valkey (leave empty for no password in development)
VALKEY_PASSWORD=

# Maximum memory Valkey can use
VALKEY_MAXMEMORY=512mb

# Bind address (use 0.0.0.0 to accept connections from any IP)
# WARNING: Only use 0.0.0.0 with VALKEY_PASSWORD set!
VALKEY_BIND=127.0.0.1

# Examples for production:
# VALKEY_PASSWORD=MyStr0ng!P@ssw0rd123
# VALKEY_MAXMEMORY=2gb
# VALKEY_BIND=0.0.0.0
